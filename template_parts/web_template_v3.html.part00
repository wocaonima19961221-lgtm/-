<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>加密市场情报分析</title>
<script src="https://unpkg.com/lightweight-charts@4.1.1/dist/lightweight-charts.standalone.production.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;}
:root{
  --bg:#0d1117;--bg2:#161b22;--card:#1c2333;--card2:#252d3f;
  --accent:#3b82f6;--accent2:#2563eb;--green:#22c55e;--red:#ef4444;--yellow:#eab308;
  --text:#e6edf3;--text2:#8b949e;--text3:#5c6570;--border:#2d3548;--border2:#3d4760;
  --shadow:0 4px 24px rgba(0,0,0,0.3);--radius:12px;--radius-sm:8px;
}
[data-theme="light"]{--bg:#f5f7fa;--bg2:#ffffff;--card:#ffffff;--card2:#f0f2f5;--accent:#3b82f6;--accent2:#2563eb;--green:#16a34a;--red:#dc2626;--yellow:#ca8a04;--text:#1f2937;--text2:#6b7280;--text3:#9ca3af;--border:#e5e7eb;--border2:#d1d5db;--shadow:0 4px 24px rgba(0,0,0,0.06);}
body{font-family:'Inter',-apple-system,BlinkMacSystemFont,sans-serif;background:var(--bg);color:var(--text);min-height:100vh;overflow:hidden;}

/* ===== Scrollbar ===== */
::-webkit-scrollbar{width:5px;}::-webkit-scrollbar-track{background:transparent;}::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px;}::-webkit-scrollbar-thumb:hover{background:var(--text3);}

/* ===== Top Nav ===== */
.nav{display:flex;align-items:center;justify-content:space-between;padding:0 28px;height:60px;background:var(--bg2);border-bottom:1px solid var(--border);position:sticky;top:0;z-index:100;position:relative;}
.nav-l{display:flex;align-items:center;gap:32px;}
.nav-logo{font-size:18px;font-weight:700;cursor:pointer;background:linear-gradient(135deg,#60a5fa,#a78bfa);-webkit-background-clip:text;-webkit-text-fill-color:transparent;letter-spacing:-0.5px;}
.nav-links{display:flex;gap:4px;}
.nav-links a{padding:6px 14px;border-radius:6px;font-size:13px;color:var(--text2);text-decoration:none;cursor:pointer;transition:all 0.15s;}
.nav-links a:hover{color:var(--text);background:var(--card);}
.nav-links a.active{color:var(--text);background:var(--card);}
.nav-r{display:flex;gap:8px;}
.nav-btn{padding:7px 18px;border-radius:7px;font-size:13px;font-weight:500;cursor:pointer;border:none;transition:all 0.15s;}
.nav-btn.primary{background:var(--accent);color:white;}
.nav-btn.primary:hover{background:var(--accent2);}
.nav-btn.ghost{background:transparent;color:var(--text2);border:1px solid var(--border);}
.nav-btn.ghost:hover{color:var(--text);border-color:var(--text3);}

/* ===== Tab Bar ===== */
.tabs{display:flex;padding:0 28px;background:var(--bg2);border-bottom:1px solid var(--border);gap:0;}
.tab{padding:11px 22px;font-size:13px;font-weight:500;cursor:pointer;color:var(--text2);border-bottom:2px solid transparent;transition:all 0.15s;display:flex;align-items:center;gap:6px;}
.tab:hover{color:var(--text);}
.tab.active{color:var(--accent);border-bottom-color:var(--accent);}

/* ===== Main Layout ===== */
.layout{display:grid;grid-template-columns:280px 1fr 300px;height:calc(100vh - 100px);overflow:hidden;}

/* ===== LEFT SIDEBAR ===== */
.left{background:var(--bg2);border-right:1px solid var(--border);display:flex;flex-direction:column;overflow:hidden;max-height:calc(100vh - 100px);}
.left .search-wrap{padding:14px 14px 10px;border-bottom:1px solid var(--border);}
.left .search-wrap input{width:100%;padding:9px 14px;background:var(--card);border:1px solid var(--border);border-radius:var(--radius-sm);color:var(--text);font-size:13px;outline:none;transition:border 0.15s;}
.left .search-wrap input:focus{border-color:var(--accent);}
.left .search-wrap input::placeholder{color:var(--text3);}
.cats{display:flex;gap:3px;padding:8px 10px 6px;flex-wrap:wrap;border-bottom:1px solid var(--border);}
.cat{padding:4px 10px;border-radius:5px;font-size:11px;font-weight:500;cursor:pointer;background:var(--card);color:var(--text2);border:none;transition:all 0.12s;}
.cat:hover{color:var(--text);}
.cat.active{background:var(--accent);color:white;}
.sort-bar{display:flex;gap:3px;padding:4px 10px 6px;border-bottom:1px solid var(--border);}
.sort-btn{padding:3px 8px;border-radius:4px;font-size:10px;cursor:pointer;background:var(--card);color:var(--text2);border:none;transition:all 0.12s;}
.sort-btn:hover{color:var(--text);}
.sort-btn.active{background:var(--accent);color:white;}
.list-header{display:grid;grid-template-columns:1fr 80px 70px;padding:7px 14px;font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:0.5px;border-bottom:1px solid var(--border);}
.list-header span:nth-child(2),.list-header span:nth-child(3){text-align:center;}
.coin-list{flex:1;overflow-y:auto;}
.coin-row{display:grid;grid-template-columns:1fr 80px 70px;padding:8px 14px;font-size:12px;cursor:pointer;border-bottom:1px solid rgba(45,53,72,0.4);transition:background 0.12s;align-items:center;}
.coin-row:hover{background:var(--card);}
.coin-row.active{background:rgba(59,130,246,0.08);border-left:2px solid var(--accent);}
.coin-row .name{font-weight:500;display:flex;align-items:center;gap:6px;overflow:hidden;line-height:18px;}
.coin-row .name img{width:18px;height:18px;border-radius:50%;flex-shrink:0;display:block;}
.coin-badge{border-radius:50%;flex-shrink:0;display:inline-flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#334155,#0f172a);border:1px solid var(--border2);color:var(--text);font-weight:800;font-family:'Inter',sans-serif;letter-spacing:0;}
.coin-badge-sm{width:18px;height:18px;font-size:8px;}
.coin-badge-md{width:20px;height:20px;font-size:8px;}
.coin-badge-lg{width:26px;height:26px;font-size:10px;margin:0 auto 6px;}
.coin-row .name .cn{color:var(--text3);font-weight:400;font-size:10px;margin-left:2px;}
.coin-row .prc{text-align:center;font-family:'SF Mono',monospace;font-size:12px;font-weight:500;line-height:18px;}
.coin-row .chg{text-align:center;font-weight:600;font-size:12px;line-height:18px;}
.coin-row .chg.up{color:var(--green);}
.coin-row .chg.down{color:var(--red);}

/* ===== CENTER ===== */
.center{padding:16px 20px;overflow-y:auto;background:var(--bg);}
.chart-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:12px 14px;box-shadow:var(--shadow);}
.chart-head-main{display:flex;align-items:center;gap:10px;min-width:0;flex-wrap:wrap;}
.chart-head-main h2{font-size:18px;font-weight:800;letter-spacing:0;white-space:nowrap;}
.chart-head-main .badge{font-size:12px;padding:3px 10px;border-radius:5px;font-weight:600;}
.chart-head-main .stat{font-size:11px;color:var(--text3);background:var(--card2);border:1px solid var(--border);border-radius:6px;padding:5px 8px;font-family:'SF Mono',monospace;white-space:nowrap;}
.chart-head-main .stat strong{color:var(--text);font-weight:800;}
.badge.bull{background:rgba(34,197,94,0.12);color:var(--green);}
.badge.bear{background:rgba(239,68,68,0.12);color:var(--red);}
.badge.neutral{background:rgba(139,148,158,0.12);color:var(--text2);}
.chart-head-actions{display:flex;gap:8px;align-items:center;flex-shrink:0;}
